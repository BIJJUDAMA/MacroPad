[meta]
version = 1
name    = "open_notepad"
created = "2026-03-16"
tags    = ["test", "windows"]

[playback]
speed           = 1.0
wait_timeout_ms = 15000
loop_count      = 1

[[events]]
type    = "key_down"
key     = "meta"
time_ms = 0

[[events]]
type    = "key_up"
key     = "meta"
time_ms = 80

[[events]]
type        = "delay"
duration_ms = 800
time_ms     = 80

[[events]]
type    = "type_text"
value   = "notepad"
time_ms = 880

[[events]]
type    = "key_down"
key     = "enter"
time_ms = 1000

[[events]]
type    = "key_up"
key     = "enter"
time_ms = 1060
