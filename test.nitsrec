[meta]
version = 1
name    = "test_macro"
created = "2026-03-15"
tags    = ["test", "demo"]

[playback]
speed           = 1.0
wait_timeout_ms = 15000
loop_count      = 1

[[events]]
type    = "key_down"
key     = "meta"
time_ms = 0

[[events]]
type    = "key_up"
key     = "meta"
time_ms = 80

[[events]]
type        = "delay"
duration_ms = 1000
time_ms     = 80

[[events]]
type    = "type_text"
value   = "notepad"
time_ms = 1080

[[events]]
type    = "key_down"
key     = "enter"
time_ms = 1200

[[events]]
type        = "delay"
duration_ms = 1500
time_ms     = 1200

[[events]]
type    = "type_text"
value   = "hello from macropad!"
time_ms = 2700
